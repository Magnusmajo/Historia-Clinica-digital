DATABASE_URL=sqlite:///./historia_clinica.db
FRONTEND_ORIGIN=http://localhost:5173
APP_TIMEZONE=America/Montevideo

# Google Calendar OAuth. Para activar la integracion, guarda el JSON de OAuth
# como credentials.json en project/backend o ajusta estas rutas.
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_REDIRECT_URI=http://localhost:8000/google-calendar/callback
